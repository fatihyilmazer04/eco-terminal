# =============================================================================
# Eco-Terminal .gitignore
# =============================================================================

# Hassas bilgiler — asla commit edilmez
.env
*.env.local
*.env.production
google-services.json
firebase-adminsdk*.json

# Kubernetes secret'ları — gerçek değerler bu dosyada olmamalı
k8s/secret.yaml

# Java / Maven
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/*.log

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Python / AI Service
ai-service/__pycache__/
ai-service/*.pyc
ai-service/.venv/
ai-service/venv/
ai-service/model/*.h5
ai-service/model/*.keras
ai-service/*.log

# Docker
*.pid

# OS
Thumbs.db

# ML Pipeline — üretilen büyük veri ve model dosyaları git'e push edilmez
ml-pipeline/data/*.parquet
ml-pipeline/data/*.png
ml-pipeline/data/*.csv
ml-pipeline/data/*.txt
ml-pipeline/models/*.pkl
ml-pipeline/models/*.json
ml-pipeline/__pycache__/
ml-pipeline/*.pyc

# Claude Code memory (local tooling — not project code)
.claude/

# Large model weights
yolov8s.pt

# Backup files
README.md.backup

# Python virtual environments
intent-training/venv/
llm-service/venv/
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo

# Large ML model weights
yolo-finetune/
**/*.pt
**/*.h5
**/*.keras
**/*.pkl

# Large ML model weights (>100MB — GitHub limit)
**/*.safetensors
**/*.bin
llm-service/app/intent/models/distilbert/model.safetensors
