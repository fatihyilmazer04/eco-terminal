{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "id": null,
  "uid": "eco-terminal-backend",
  "title": "Eco-Terminal — Backend Metrikleri",
  "description": "Spring Boot Actuator + HikariCP + JVM metrikleri",
  "tags": ["eco-terminal", "spring-boot", "jvm"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Toplam İstek / dk",
      "description": "Son 5 dakikadaki HTTP istek oranı (req/dk)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
        "expr": "round(sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\"}[5m])) * 60, 0.1)",
        "legendFormat": "req/dk",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Hata Oranı (5xx)",
      "description": "Son 5 dakikadaki sunucu hatası yüzdesi",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
        "expr": "100 * sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\"}[5m]))",
        "legendFormat": "5xx %",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "noValue": "0"
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Aktif DB Bağlantısı",
      "description": "HikariCP aktif bağlantı sayısı",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
        "expr": "hikaricp_connections_active{job=\"eco-terminal-backend\"}",
        "legendFormat": "Aktif",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 18 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "JVM Heap Kullanımı",
      "description": "Kullanılan / maksimum heap bellek (MB)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
        "expr": "100 * sum(jvm_memory_used_bytes{job=\"eco-terminal-backend\",area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"eco-terminal-backend\",area=\"heap\"})",
        "legendFormat": "Heap %",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "noValue": "0"
        },
        "overrides": []
      }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "JVM Bellek Kullanımı",
      "description": "Heap ve non-heap bellek kullanımı (MB cinsinden)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "sum(jvm_memory_used_bytes{job=\"eco-terminal-backend\",area=\"heap\"}) / 1048576",
          "legendFormat": "Heap Kullanılan (MB)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "sum(jvm_memory_max_bytes{job=\"eco-terminal-backend\",area=\"heap\"}) / 1048576",
          "legendFormat": "Heap Maksimum (MB)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "sum(jvm_memory_used_bytes{job=\"eco-terminal-backend\",area=\"nonheap\"}) / 1048576",
          "legendFormat": "Non-Heap Kullanılan (MB)",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Heap Maksimum (MB)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } }
            ]
          }
        ]
      }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP İstek Oranı",
      "description": "Durum koduna göre saniyedeki istek sayısı (req/s)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\",status=~\"2..\"}[5m]))",
          "legendFormat": "2xx (Başarılı)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\",status=~\"4..\"}[5m]))",
          "legendFormat": "4xx (İstemci Hatası)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx (Sunucu Hatası)",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx (Başarılı)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#2ECC71" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx (İstemci Hatası)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F39C12" } }]
          },
          {
            "matcher": { "id": "byName", "options": "5xx (Sunucu Hatası)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#E74C3C" } }]
          }
        ]
      }
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "HTTP Yanıt Süreleri (Persentil)",
      "description": "p50, p95, p99 yanıt süreleri — milisaniye",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"eco-terminal-backend\"}[5m]))) * 1000",
          "legendFormat": "p50 (Medyan)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"eco-terminal-backend\"}[5m]))) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"eco-terminal-backend\"}[5m]))) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#E74C3C" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F39C12" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p50 (Medyan)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#2ECC71" } }]
          }
        ]
      }
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "HikariCP Veritabanı Bağlantı Havuzu",
      "description": "Aktif, bekleyen ve boştaki bağlantı sayıları",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "hikaricp_connections_active{job=\"eco-terminal-backend\"}",
          "legendFormat": "Aktif Bağlantı",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "hikaricp_connections_idle{job=\"eco-terminal-backend\"}",
          "legendFormat": "Boşta",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "hikaricp_connections_pending{job=\"eco-terminal-backend\"}",
          "legendFormat": "Bekleyen",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "hikaricp_connections_max{job=\"eco-terminal-backend\"}",
          "legendFormat": "Maksimum (limit)",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Aktif Bağlantı" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3B82F6" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Bekleyen" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#E74C3C" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Maksimum (limit)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } }
            ]
          }
        ]
      }
    },

    {
      "id": 30,
      "type": "bargauge",
      "title": "En Fazla İstek Alan API Endpoint'leri",
      "description": "Son 5 dakikada URI bazında toplam istek sayısı (Top 10)",
      "gridPos": { "x": 0, "y": 22, "w": 14, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
        "expr": "topk(10, sum by (uri, method) (increase(http_server_requests_seconds_count{job=\"eco-terminal-backend\", uri!~\"/actuator.*\"}[5m])))",
        "legendFormat": "{{method}} {{uri}}",
        "refId": "A",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "short",
          "custom": { "fillOpacity": 80 }
        },
        "overrides": []
      }
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "Hata Oranı (4xx & 5xx)",
      "description": "Toplam isteklere oranla hata yüzdesi",
      "gridPos": { "x": 14, "y": 22, "w": 10, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "100 * sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\",status=~\"4..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\"}[5m]))",
          "legendFormat": "4xx Hata %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "100 * sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"eco-terminal-backend\"}[5m]))",
          "legendFormat": "5xx Hata %",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "4xx Hata %" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F39C12" } }]
          },
          {
            "matcher": { "id": "byName", "options": "5xx Hata %" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#E74C3C" } }]
          }
        ]
      }
    },

    {
      "id": 40,
      "type": "timeseries",
      "title": "JVM Thread Sayısı",
      "description": "Canlı thread sayısı",
      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "jvm_threads_live_threads{job=\"eco-terminal-backend\"}",
          "legendFormat": "Canlı Thread",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
          "expr": "jvm_threads_daemon_threads{job=\"eco-terminal-backend\"}",
          "legendFormat": "Daemon Thread",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      }
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "JVM GC Süresi",
      "description": "Garbage Collector'ın harcadığı süre (saniye/saniye)",
      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
        "expr": "sum by (action, cause) (rate(jvm_gc_pause_seconds_sum{job=\"eco-terminal-backend\"}[5m]))",
        "legendFormat": "GC {{action}} ({{cause}})",
        "refId": "A"
      }],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      }
    },

    {
      "id": 42,
      "type": "gauge",
      "title": "CPU Kullanımı (JVM Process)",
      "description": "JVM process CPU kullanım oranı",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus-eco" },
        "expr": "process_cpu_usage{job=\"eco-terminal-backend\"} * 100",
        "legendFormat": "CPU %",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    }

  ]
}
