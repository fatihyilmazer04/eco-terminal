#!/bin/sh
# Maven Wrapper Script — Apache Maven 3.9.6
# https://maven.apache.org/wrapper/

set -e

# Determine wrapper jar location
MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
    DOWNLOAD_URL=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2)
fi

# Download maven if not present
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper..."
    curl -sS -o "$MAVEN_WRAPPER_JAR" \
        "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
fi

exec java -jar "$MAVEN_WRAPPER_JAR" "$@"
