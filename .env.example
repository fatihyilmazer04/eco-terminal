# =============================================================================
# Eco-Terminal — Ortam Değişkenleri
# Kullanım: cp .env.example .env  →  değerleri doldur  →  docker-compose up
# .env dosyasını asla Git'e ekleme!
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=ecoterminal
POSTGRES_USER=ecoterminal
POSTGRES_PASSWORD=your_strong_password_here

# ── Backend ──────────────────────────────────────────────────────────────────
# JWT secret — en az 64 karakter, rastgele oluştur:
#   openssl rand -base64 64
JWT_SECRET=your_jwt_secret_minimum_64_chars_replace_this_with_a_real_secret

# ── AI Servisi ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:5000

# ── Firebase FCM (opsiyonel) ─────────────────────────────────────────────────
# Gerçek bildirimler için Firebase Console'dan indirilen service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ── Spring Profili ───────────────────────────────────────────────────────────
SPRING_PROFILE=dev
