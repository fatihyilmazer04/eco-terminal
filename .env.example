# =============================================================================
# Eco-Terminal — Ortam Değişkenleri
# Kullanım: cp .env.example .env  →  değerleri doldur  →  docker-compose up
# .env dosyasını asla Git'e ekleme!
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=ecoterminal
POSTGRES_USER=ecoterminal
POSTGRES_PASSWORD=your_strong_password_here

# ── Backend ──────────────────────────────────────────────────────────────────
# JWT secret — en az 64 karakter, rastgele oluştur:
#   openssl rand -base64 64
JWT_SECRET=your_jwt_secret_minimum_64_chars_replace_this_with_a_real_secret

# ── AI Servisi ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:5000

# ── Firebase FCM (opsiyonel) ─────────────────────────────────────────────────
# Gerçek bildirimler için Firebase Console'dan indirilen service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ── Spring Profili ───────────────────────────────────────────────────────────
SPRING_PROFILE=dev

# ── Email Doğrulama (SMTP) ───────────────────────────────────────────────────
# Demo modu (default): MAIL_ENABLED=false → kod backend log'una yazılır, mail gönderilmez
# Gerçek mod: MAIL_ENABLED=true + Gmail hesabı + Uygulama Şifresi gerekli
#
# Gmail Uygulama Şifresi almak için:
#   1. Google Hesabım → Güvenlik → 2 Adımlı Doğrulama (aktif olmalı)
#   2. Güvenlik → Uygulama şifreleri → "Diğer" → "eco-terminal" → Oluştur
#   3. Üretilen 16 karakterlik şifreyi MAIL_PASSWORD'a yaz
#
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_ENABLED=false

# ── Chatbot / Gemini LLM ─────────────────────────────────────────────────────
# Google AI Studio'dan ücretsiz API anahtarı: https://aistudio.google.com/app/apikey
# Boş bırakılırsa chatbot "API key eksik" mesajı döner (uygulama çalışmaya devam eder)
GEMINI_API_KEY=

# ── LLM Service Internal Token ───────────────────────────────────────────────
# llm-service → backend arası kimlik doğrulama.
# Üretimde güçlü bir değerle değiştir: openssl rand -hex 32
LLM_SERVICE_INTERNAL_TOKEN=ecoterminal-llm-internal-secret-change-in-production
